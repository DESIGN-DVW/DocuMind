  "relationshipTypes": [
    "imports",
    "parent_of",
    "variant_of",
    "supersedes",
    "depends_on",
    "related_to",
    "generated_from",
    "dispatched_to"
  ],
  "lintRules": {
    "profile": "strict",
    "customPatternsPath": "config/custom-error-patterns.json"
  }
}
