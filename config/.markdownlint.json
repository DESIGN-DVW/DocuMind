{
  "$schema": "https://raw.githubusercontent.com/DavidAnson/markdownlint/main/schema/markdownlint-config-schema.json",
  "default": true,

  "// CORE RULES - Enforced": "",
  "MD001": true,
  "MD003": { "style": "atx" },
  "MD009": true,
  "MD010": true,
  "MD012": { "maximum": 1 },
  "MD018": true,
  "MD019": true,
  "MD022": { "lines_above": 1, "lines_below": 1 },
  "MD023": true,
  "MD025": true,
  "MD026": false,
  "MD027": true,
  "MD028": true,
  "MD030": true,
  "MD031": { "list_items": true },
  "MD032": true,
  "MD036": true,
  "MD037": true,
  "MD038": true,
  "MD039": true,
  "MD040": true,
  "// MD040: GLOBAL POLICY - ALL code blocks MUST have type. Auto-fix script uses 'text' as minimum default": "",
  "MD041": false,
  "MD046": { "style": "fenced" },
  "MD047": true,
  "MD049": { "style": "asterisk" },
  "MD050": { "style": "asterisk" },

  "// RELAXED RULES": "",
  "MD013": false,
  "MD024": { "siblings_only": true },
  "MD033": {
    "allowed_elements": [
      "br",
      "details",
      "summary",
      "kbd",
      "sup",
      "sub",
      "img",
      "a"
    ]
  },
  "MD034": true,
  "MD035": { "style": "---" },

  "// DISABLED RULES": "",
  "MD002": false,
  "MD004": false,
  "MD005": false,
  "MD006": false,
  "MD007": false,
  "MD011": false,
  "MD014": false,
  "MD029": false,
  "MD042": false,
  "MD043": false,
  "MD044": false,
  "MD045": false,
  "MD048": false,
  "MD051": false,
  "MD052": false,
  "MD053": false,

  "// RULE DESCRIPTIONS": "",
  "// MD001: Heading levels should only increment by one level at a time": "",
  "// MD003: Heading style (atx = #, not underline)": "",
  "// MD009: Trailing spaces": "",
  "// MD010": "Hard tabs": "",
  "// MD012: Multiple consecutive blank lines": "",
  "// MD013: Line length (disabled - too strict for links)": "",
  "// MD022": "Headings should be surrounded by blank lines": "",
  "// MD031": "Fenced code blocks should be surrounded by blank lines": "",
  "// MD032": "Lists should be surrounded by blank lines": "",
  "// MD033": "Inline HTML (allow some tags)": "",
  "// MD036": "Emphasis used instead of a heading": "",
  "// MD040": "Fenced code blocks should have a language specified": "",
  "// MD041": "First line in file should be a top level heading (disabled)": "",
  "// MD047": "Files should end with a single newline": ""
}
