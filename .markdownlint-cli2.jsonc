// markdownlint-cli2 configuration — canonical source in RootDispatcher
// Deployed to every repo root by: node scripts/sync-markdown-config.mjs
// DO NOT edit deployed copies directly — edit here and re-run the sync script
{
  "customRules": [
    "./config/rules/table-separator-spacing.cjs",
    "./config/rules/no-blank-lines-in-tables.cjs"
  ],
  "config": {
    "MD013": false,
    "MD060": false
  },
  "ignores": [
    "node_modules",
    ".git",
    "dist",
    "build",
    ".planning",
    ".claude",
    "temp",
    "tmp",
    "backup",
    "backups",
    "archive",
    "_archive",
    "archives",
    "docs/slides",
    "config/markdownlint"
  ],
  "overrides": [
    {
      "globs": ["docs/slides/**/*.md"],
      "config": {
        "MD025": false,
        "MD036": false
      }
    }
  ]
}
