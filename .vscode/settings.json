{
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "markdown.styles": [
    "./config/markdown-preview/preview.css"
  ],
  "markdownlint.config": {
    "extends": "./.markdownlint-cli2.jsonc"
  }
}
