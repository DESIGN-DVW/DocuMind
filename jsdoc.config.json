{
  "source": {
    "include": [
      "scripts",
      "config",
      "data",
      "docs",
      "index"
    ],
    "includePattern": "\\.(js|mjs)$",
    "excludePattern": "(node_modules|dist|build|storybook-static|\\.test\\.|\\.stories\\.|mock)"
  },
  "opts": {
    "template": "node_modules/docdash",
    "encoding": "utf8",
    "destination": "./docs/07-api/jsdoc/",
    "recurse": true,
    "verbose": true,
    "readme": "./README.md"
  },
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": [
      "jsdoc",
      "closure"
    ]
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "outputSourceFiles": true,
      "includeDate": true
    },
    "docdash": {
      "static": true,
      "sort": true,
      "search": true,
      "collapse": true,
      "typedefs": true,
      "removeQuotes": "none",
      "scripts": [],
      "menu": {
        "GitHub": {
          "href": "https://github.com/DESIGN-DVW/DocuMind",
          "target": "_blank",
          "class": "menu-item",
          "id": "repository"
        },
        "Storybook": {
          "href": "/storybook",
          "target": "_blank",
          "class": "menu-item"
        }
      }
    }
  },
  "plugins": [
    "plugins/markdown",
    "node_modules/better-docs/typescript",
    "node_modules/better-docs/component"
  ],
  "markdown": {
    "parser": "gfm",
    "hardwrap": false,
    "idInHeadings": true
  }
}
