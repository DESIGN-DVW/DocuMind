# DocuMind Environment Configuration
# Copy this file to .env and adjust values for your environment.
# .env is gitignored — local paths never get committed.
#
# Docker users: pass these as environment variables directly.
# Example: docker run -e PORT=9000 -e DOCUMIND_REPOS_DIR=/repos documind

# ============================================================================
# SERVER
# ============================================================================

# HTTP port for the DocuMind API
PORT=9000

# ============================================================================
# DATABASE
# ============================================================================

# Path to the SQLite database file (relative to project root, or absolute)
DOCUMIND_DB=data/documind.db

# ============================================================================
# PROFILE
# ============================================================================

# Path to the active repository profile JSON (relative to project root, or absolute)
DOCUMIND_PROFILE=config/profiles/dvwdesign.json

# ============================================================================
# REPOSITORY ROOT
# ============================================================================

# Base directory containing all repositories to scan.
# When set, DocuMind discovers repos by walking this directory.
# When unset, the profile/registry defines which repos to scan.
#
# macOS local development (default fallback in constants.mjs):
DOCUMIND_REPOS_DIR=/Users/Shared/htdocs/github/DVWDesign
#
# Docker example:
# DOCUMIND_REPOS_DIR=/repos

# ============================================================================
# EXPLICIT REPO LIST (optional)
# ============================================================================

# Comma-separated list of repository names to scan.
# When set, only these repos are scanned regardless of DOCUMIND_REPOS_DIR.
# When unset, all repos discovered via DOCUMIND_REPOS_DIR or profile are used.
# DOCUMIND_REPOS=DocuMind,RootDispatcher,CampaignManager

# ============================================================================
# CRON SCHEDULES (optional — defaults shown, uncomment to override)
# ============================================================================

# File watcher heartbeat check
# DOCUMIND_CRON_HEARTBEAT=*/15 * * * *

# Incremental scan (changed files only)
# DOCUMIND_CRON_HOURLY=0 * * * *

# Full scan + similarity detection + deviation analysis
# DOCUMIND_CRON_DAILY=0 2 * * *

# PDF re-index + keyword refresh + graph rebuild
# DOCUMIND_CRON_WEEKLY=0 3 * * 0

# Relink processor check
# DOCUMIND_CRON_RELINK=0 */6 * * *

# ============================================================================
# INGESTION MODE
# ============================================================================

# mount = scan bind-mounted host directories (default)
# clone = clone repos from GitHub on startup, pull on schedule
REPO_MODE=mount

# --- Clone Mode Settings (only used when REPO_MODE=clone) ---

# Comma-separated org/repo slugs to clone
# DOCUMIND_REPOS=DVWDesign/DocuMind,DVWDesign/RootDispatcher

# GitHub personal access token (never commit this!)
# GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# When using clone mode, set DOCUMIND_REPOS_DIR to the clone target directory
# DOCUMIND_REPOS_DIR=/app/repos

# --- Mount Mode Settings (only used when REPO_MODE=mount) ---

# Host path for bind mount (used in docker-compose.yml)
# REPOS_HOST_PATH=/Users/Shared/htdocs/github/DVWDesign

# ============================================================================
# MCP TRANSPORT
# ============================================================================

# MCP transport mode: stdio (default, local Claude Code) or http (remote consumers)
DOCUMIND_MCP_MODE=stdio

# Bearer token(s) for MCP HTTP endpoint (required when DOCUMIND_MCP_MODE=http)
# Comma-separated for multiple consumers
# DOCUMIND_MCP_TOKEN=your-secret-token-here

# Allowed CORS origins for MCP HTTP endpoint (comma-separated, optional)
# Use * to allow all origins. Leave empty/unset to disable CORS headers.
# DOCUMIND_MCP_CORS_ORIGINS=https://example.com,https://app.example.com

# ============================================================================
# PRESENTATION PIPELINE
# ============================================================================

# DeepL API key for EN -> FR slide translation (required for the translate stage)
# Get one at https://www.deepl.com/pro-api — never commit a real key!
# DEEPL_API_KEY=your-deepl-api-key-here

# FTP credentials for slide deploy. When absent, deploy runs in dry-run mode
# (logs intended uploads, uploads nothing).
# FTP_HOST=ftp.example.com
# FTP_USER=your-ftp-username
# FTP_PASSWORD=your-ftp-password

# Remote path on the web host where rendered slides are published
FTP_REMOTE_PATH=/public_html/slides

# Absolute path to the LibreOffice soffice binary (needed for editable PPTX export).
# macOS default install location shown; adjust for Linux/Docker.
SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
