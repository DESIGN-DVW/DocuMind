{
  "name": "@design-dvw/documind",
  "version": "1.0.0",
  "description": "DocuMind - Documentation Intelligence & Management System for DESIGN-DVW organization",
  "type": "module",
  "main": "scripts/index-markdown.mjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/DESIGN-DVW/DocuMind.git"
  },
  "homepage": "https://github.com/DESIGN-DVW/DocuMind",
  "bugs": {
    "url": "https://github.com/DESIGN-DVW/DocuMind/issues"
  },
  "scripts": {
    "scan": "node scripts/scan-all-repos.mjs",
    "scan:report": "node scripts/scan-all-repos.mjs --report",
    "index": "node scripts/index-markdown.mjs",
    "index:update": "node scripts/index-markdown.mjs --update",
    "lint": "markdownlint-cli2 '**/*.md' '#node_modules' '#index' --config config/.markdownlint.json",
    "lint:fix": "markdownlint-cli2 '**/*.md' '#node_modules' '#index' --config config/.markdownlint.json --fix",
    "fix": "node scripts/fix-markdown.mjs",
    "fix:all": "node scripts/fix-markdown.mjs --all",
    "validate": "node scripts/validate-timestamps.mjs",
    "validate:fix": "node scripts/validate-timestamps.mjs --fix",
    "watch": "node scripts/watch-and-index.mjs",
    "cron:setup": "node scripts/setup-cron.mjs",
    "cron:stop": "node scripts/setup-cron.mjs --stop",
    "cron:list": "node scripts/setup-cron.mjs --list",
    "db:init": "node scripts/db/init-database.mjs",
    "db:reset": "rm -f data/documind.db && npm run db:init",
    "scan:enhanced": "node scripts/scan/enhanced-scanner.mjs",
    "analyze:similarities": "node scripts/analysis/detect-similarities.mjs",
    "analyze:deviations": "node scripts/analysis/detect-deviations.mjs",
    "analyze:all": "npm run analyze:similarities && npm run analyze:deviations",
    "report:dashboard": "node scripts/reports/deviation-dashboard.mjs",
    "report:canonical": "node scripts/reports/canonical-report.mjs",
    "tree:visual": "tree -I 'node_modules|.git|dist|build|coverage|.next|.cache' -L 3 --dirsfirst",
    "tree:structure": "tree -I 'node_modules|.git|dist|build|coverage|.next|.cache' -L 4 > docs/REPOSITORY-STRUCTURE.txt",
    "tree:schema": "node scripts/generate-tree-schema.mjs",
    "tree:update": "npm run tree:structure && npm run tree:schema",
    "docs:jsdoc": "jsdoc -c jsdoc.config.json",
    "docs:jsdoc:serve": "npx serve docs/07-api/jsdoc",
    "docs:generate": "npm run docs:jsdoc",
    "docs:generate:all": "npm run docs:jsdoc",
    "links:check": "find . -name '*.md' -not -path './node_modules/*' -not -path './index/*' -not -path './.git/*' | xargs markdown-link-check --config config/.markdown-link-check.json",
    "diagram:generate": "mmdc -i docs/diagrams/source.mmd -o docs/diagrams/output.png",
    "validate:custom": "node scripts/validate-custom-errors.mjs",
    "validate:custom:all": "node scripts/validate-custom-errors.mjs --all",
    "fix:custom": "node scripts/fix-custom-errors.mjs",
    "fix:custom:all": "node scripts/fix-custom-errors.mjs --all",
    "fix:custom:dry-run": "node scripts/fix-custom-errors.mjs --dry-run",
    "analyze:patterns": "node scripts/analyze-error-patterns.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.md": [
      "markdownlint-cli2 --fix --config config/.markdownlint.json"
    ],
    "**/*.{js,mjs,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "markdown",
    "linting",
    "documentation",
    "indexing",
    "registry",
    "automation"
  ],
  "author": "DESIGN-DVW",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "date-fns": "^3.0.6",
    "diff": "^5.1.0",
    "fast-glob": "^3.3.2",
    "fast-levenshtein": "^3.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "ignore": "^5.3.0",
    "markdown-it": "^14.0.0",
    "node-cron": "^3.0.3",
    "ora": "^8.0.1",
    "string-similarity": "^4.0.4",
    "table": "^6.8.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "better-docs": "^2.7.3",
    "docdash": "^2.0.2",
    "husky": "^9.1.7",
    "jsdoc": "^4.0.5",
    "lint-staged": "^16.2.6",
    "markdown-link-check": "^3.14.1",
    "markdownlint-cli2": "^0.15.0",
    "prettier": "^3.6.2",
    "puppeteer": "^24.30.0",
    "tree-cli": "^0.6.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
