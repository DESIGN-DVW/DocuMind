{
  "permissions": {
    "allow": [
      "Bash(find /Users/Shared/htdocs/github/DVWDesign/DocuMind -type f \\\\\\(-name *mcp* -o -name *integration* \\\\\\))",
      "Bash(sqlite3 /Users/Shared/htdocs/github/DVWDesign/DocuMind/data/documind.db \".tables\")",
      "Bash(curl -s http://localhost:9000/health)",
      "Bash(sqlite3 /Users/Shared/htdocs/github/DVWDesign/DocuMind/data/documind.db \"SELECT COUNT\\(*\\) as doc_count FROM documents; SELECT COUNT\\(*\\) as rel_count FROM doc_relationships; SELECT COUNT\\(*\\) as keyword_count FROM keywords; SELECT COUNT\\(*\\) as diagram_count FROM diagrams;\")",
      "Skill(gsd:map-codebase)",
      "Skill(gsd:map-codebase:*)",
      "Bash(npx markdownlint-cli2:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Auto-fixing ESLint issues..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Auto-fixing ESLint issues..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "npx eslint . 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Linting before commit..."
          }
        ]
      }
    ]
  }
}
